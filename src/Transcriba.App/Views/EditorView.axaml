<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             xmlns:views="using:Transcriba.App.Views"
             xmlns:controls="using:Transcriba.App.Controls"
             x:Class="Transcriba.App.Views.EditorView"
             x:DataType="vm:EditorViewModel">
    <Grid Classes="editor-shell" RowDefinitions="*,Auto">
        <ScrollViewer x:Name="TranscriptScroll"
                      Grid.Row="0"
                      Classes="editor-transcript"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Classes="editor-transcript-inner" Spacing="0">
                <StackPanel Classes="editor-breadcrumb" Orientation="Horizontal" Spacing="4">
                    <Button Classes="breadcrumb-link"
                            Content="Biblioteca"
                            Command="{Binding NavigateDashboardCommand}" />
                    <TextBlock Text="›"
                               Foreground="{DynamicResource TranscribaMuted}"
                               FontSize="12"
                               IsVisible="{Binding HasResearchBreadcrumb}" />
                    <Button Classes="breadcrumb-link"
                            Content="{Binding ResearchTitle}"
                            Command="{Binding NavigateResearchCommand}"
                            IsVisible="{Binding HasResearchBreadcrumb}" />
                    <TextBlock Text="›"
                               Foreground="{DynamicResource TranscribaMuted}"
                               FontSize="12" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TranscribaMuted}">
                        <Run Text="{Binding Icon}" />
                        <Run Text=" " />
                        <Run Text="{Binding Title}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Classes="editor-title-row" Orientation="Horizontal" Spacing="12">
                    <Button Classes="editor-page-icon"
                            Classes.has-icon="{Binding HasIcon}"
                            Command="{Binding ToggleIconPickerCommand}">
                        <TextBlock Text="{Binding Icon, TargetNullValue='+'}"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <TextBox Classes="editor-title-input"
                             Text="{Binding Title}"
                             LostFocus="OnTitleLostFocus"
                             KeyDown="OnTitleKeyDown" />
                </StackPanel>

                <StackPanel Classes="editor-meta" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding MetaDate}" />
                    <Border Classes="editor-meta-dot" Width="3" Height="3" CornerRadius="1.5" />
                    <TextBlock Text="{Binding MetaDuration}" />
                    <Border Classes="editor-meta-dot" Width="3" Height="3" CornerRadius="1.5" />
                    <TextBlock Text="{Binding MetaSpeakerCount}" />
                </StackPanel>

                <ItemsControl Classes="editor-tags" ItemsSource="{Binding Tags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TranscriptionCardTagViewModel">
                            <Border Classes="tag"
                                    Classes.tag-blue="{Binding IsBlue}"
                                    Classes.tag-green="{Binding IsGreen}"
                                    Classes.tag-yellow="{Binding IsYellow}"
                                    Classes.tag-red="{Binding IsRed}"
                                    Classes.tag-purple="{Binding IsPurple}"
                                    Classes.tag-orange="{Binding IsOrange}"
                                    Classes.tag-pink="{Binding IsPink}"
                                    Classes.tag-teal="{Binding IsTeal}"
                                    Margin="0,0,5,5">
                                <TextBlock Text="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Classes="status-badge status-progress"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"
                        IsVisible="{Binding IsInProgress}">
                    <TextBlock Text="{Binding StatusMessage}" />
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           Classes="dash-card-error"
                           Margin="0,0,0,12"
                           IsVisible="{Binding IsError}" />

                <Grid Classes="editor-toolbar" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
                    <Button Grid.Column="0"
                            Content="Dividir"
                            Command="{Binding SplitSegmentCommand}" />
                    <Button Grid.Column="1"
                            Content="Mesclar"
                            Command="{Binding MergeSegmentCommand}" />
                    <Border Grid.Column="2" Classes="editor-toolbar-sep" Width="1" Height="16" />
                    <Button Grid.Column="3"
                            Content="Locutor"
                            Command="{Binding ToggleSpeakerDropdownCommand}" />
                    <Border Grid.Column="4" Classes="editor-toolbar-sep" Width="1" Height="16" />
                    <Button Grid.Column="5"
                            Content="Exportar"
                            Command="{Binding ExportCommand}" />

                    <Border Grid.Column="0"
                            Grid.ColumnSpan="6"
                            Classes="icon-popup"
                            Classes.open="{Binding IsIconPickerOpen}"
                            IsVisible="{Binding IsIconPickerOpen}"
                            Margin="0,36,0,0"
                            HorizontalAlignment="Left"
                            ZIndex="10">
                        <StackPanel>
                            <TextBlock Text="Ícone" Classes="icon-popup-title" />
                            <controls:IconPicker DataContext="{Binding IconPicker}" />
                        </StackPanel>
                    </Border>

                    <views:SpeakerDropdown Grid.Column="3"
                                           DataContext="{Binding SpeakerDropdown}"
                                           Margin="0,36,0,0"
                                           HorizontalAlignment="Left"
                                           ZIndex="10" />
                </Grid>

                <ListBox x:Name="SegmentsList"
                         ItemsSource="{Binding Segments}"
                         IsVisible="{Binding HasSegments}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentItemViewModel">
                            <Border Classes="seg"
                                    Classes.active-seg="{Binding IsActive}"
                                    PointerPressed="OnSegmentPointerPressed">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0"
                                               Classes="seg-time"
                                               Text="{Binding TimeDisplay}" />
                                    <StackPanel Grid.Column="1" Classes="seg-body" Spacing="1">
                                        <TextBlock Classes="seg-speaker"
                                                   Text="{Binding SpeakerName}"
                                                   Foreground="{Binding SpeakerColorHex}"
                                                   IsVisible="{Binding SpeakerName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        <TextBox Classes="seg-text"
                                                 Text="{Binding Text}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 LostFocus="OnSegmentTextLostFocus"
                                                 GotFocus="OnSegmentTextGotFocus"
                                                 Tag="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>

        <views:PlayerBarView Grid.Row="1" DataContext="{Binding PlayerBar}" />
    </Grid>
</UserControl>
