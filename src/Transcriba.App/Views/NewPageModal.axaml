<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             xmlns:controls="using:Transcriba.App.Controls"
             x:Class="Transcriba.App.Views.NewPageModal"
             x:DataType="vm:NewPageModalViewModel">
    <Grid Background="#73000000">
        <Border Classes="modal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource TranscribaBg}"
                CornerRadius="{DynamicResource TranscribaRadiusLg}"
                Padding="24"
                Width="460"
                BoxShadow="0 8 32 0 #40000000">
            <StackPanel Spacing="0">
                <TextBlock Text="{Binding ModalTitle}"
                           Classes="modal-title" />

                <TextBlock Text="ÍCONE" Classes="picker-label" />
                <controls:IconPicker DataContext="{Binding IconPicker}" Margin="0,0,0,16" />

                <StackPanel IsVisible="{Binding IsResearchMode}" Spacing="0">
                    <TextBlock Text="COR" Classes="picker-label" />
                    <controls:ColorPicker DataContext="{Binding ColorPicker}" Margin="0,0,0,16" />
                </StackPanel>

                <Border Classes="icon-preview" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Classes="icon-preview-emoji"
                                Classes.tag-blue="{Binding IsBlue}"
                                Classes.tag-green="{Binding IsGreen}"
                                Classes.tag-purple="{Binding IsPurple}"
                                Classes.tag-orange="{Binding IsOrange}"
                                Classes.tag-pink="{Binding IsPink}"
                                Classes.tag-yellow="{Binding IsYellow}"
                                Classes.tag-red="{Binding IsRed}"
                                Classes.tag-teal="{Binding IsTeal}">
                            <TextBlock Text="{Binding PreviewIcon}" FontSize="28" />
                        </Border>
                        <TextBlock Text="{Binding PreviewTitle}"
                                   Classes="icon-preview-text"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Classes="modal-field">
                    <TextBlock Text="TÍTULO" Classes="modal-field-label" />
                    <TextBox Text="{Binding Title}"
                             PlaceholderText="Ex.: Mobilidade Urbana — Tese 2025"
                             Classes="modal-input" />
                </StackPanel>

                <StackPanel Classes="modal-field"
                            IsVisible="{Binding IsTranscriptionMode}">
                    <TextBlock Text="TAGS (VÍRGULA)" Classes="modal-field-label" />
                    <TextBox Text="{Binding TagsText}"
                             PlaceholderText="entrevista, campo, piloto"
                             Classes="modal-input" />
                </StackPanel>

                <StackPanel Classes="modal-actions" Orientation="Horizontal" Spacing="8">
                    <Button Content="Cancelar"
                            Classes="modal-cancel"
                            Command="{Binding CancelCommand}" />
                    <Button Content="Criar"
                            Classes="modal-confirm"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
