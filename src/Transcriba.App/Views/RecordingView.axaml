<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             x:Class="Transcriba.App.Views.RecordingView"
             x:DataType="vm:RecordingViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,40,56,32" Spacing="0">
            <StackPanel Classes="screen-header" Spacing="4">
                <TextBlock Text="Gravação ao vivo" Classes="screen-title" />
                <TextBlock Text="Grave áudio ou vídeo e transcreva em tempo real"
                           Classes="screen-subtitle" />
            </StackPanel>

            <StackPanel Classes="rec-container">
                <StackPanel Classes="rec-devices">
                    <ComboBox Classes="rec-select"
                              ItemsSource="{Binding MicrophoneOptions}"
                              SelectedItem="{Binding SelectedMicrophone}" />
                    <ComboBox Classes="rec-select"
                              ItemsSource="{Binding SourceOptions}"
                              SelectedItem="{Binding SelectedSource}" />
                </StackPanel>

                <StackPanel Classes="rec-main">
                    <TextBlock Text="{Binding TimerDisplay}" Classes="rec-timer" />
                    <StackPanel Classes="rec-status">
                        <Ellipse Classes="rec-dot"
                                 Classes.live="{Binding IsLive}" />
                        <TextBlock Text="{Binding StatusText}" Classes="rec-status-text" />
                    </StackPanel>

                    <StackPanel Classes="rec-controls">
                        <Button Classes="rec-btn rec-btn-secondary"
                                Command="{Binding TogglePauseCommand}"
                                IsVisible="{Binding ShowPauseStop}">
                            <Path Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Fill="{Binding $parent[Button].Foreground}"
                                  Data="M6,4 L10,4 L10,20 L6,20 Z M14,4 L18,4 L18,20 L14,20 Z" />
                        </Button>

                        <Button Classes="rec-btn rec-btn-record"
                                Classes.recording="{Binding IsRecordButtonRecording}"
                                Command="{Binding StartRecordingCommand}">
                            <Panel>
                                <Path Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Fill="{Binding $parent[Button].Foreground}"
                                      IsVisible="{Binding !IsRecordButtonRecording}"
                                      Data="M12,5 A7,7 0 1,1 12,19 A7,7 0 1,1 12,5 Z" />
                                <Path Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Fill="{Binding $parent[Button].Foreground}"
                                      IsVisible="{Binding IsRecordButtonRecording}"
                                      Data="M6,6 L18,6 L18,18 L6,18 Z" />
                            </Panel>
                        </Button>

                        <Button Classes="rec-btn rec-btn-secondary"
                                Command="{Binding StopRecordingCommand}"
                                IsVisible="{Binding ShowPauseStop}">
                            <Path Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Fill="{Binding $parent[Button].Foreground}"
                                  Data="M6,6 L18,6 L18,18 L6,18 Z" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding WaveformBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Classes="rec-waveform" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WaveformBarViewModel">
                            <Border Classes="rec-wave-bar"
                                    Classes.active="{Binding IsActive}"
                                    Height="{Binding Height}"
                                    HorizontalAlignment="Stretch" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Classes="rec-live-section"
                        IsVisible="{Binding ShowLiveSection}">
                    <StackPanel Spacing="0">
                        <Border Classes="rec-live-header">
                            <StackPanel Classes="rec-live-header">
                                <Ellipse Classes="rec-dot live" />
                                <TextBlock Text="Transcrição em tempo real"
                                           Classes="rec-live-header-title" />
                            </StackPanel>
                        </Border>
                        <ScrollViewer Classes="rec-live-body"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LiveSegments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LiveSegmentViewModel">
                                        <StackPanel Classes="rec-live-segment">
                                            <TextBlock Text="{Binding Speaker}"
                                                       Classes="rec-live-speaker"
                                                       Classes.speaker-a="{Binding IsSpeakerA}"
                                                       Classes.speaker-b="{Binding !IsSpeakerA}" />
                                            <TextBlock Text="{Binding Text}" Classes="rec-live-text" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
