<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             x:Class="Transcriba.App.Views.PlayerBarView"
             x:DataType="vm:PlayerBarViewModel">
    <Border Classes="player-bar">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Classes="player-btn player-btn-main"
                    Command="{Binding TogglePlayCommand}">
                <Panel>
                    <Path IsVisible="{Binding !IsPlaying}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Data="M5 3 L19 12 L5 21 Z"
                          Fill="White" />
                    <StackPanel IsVisible="{Binding IsPlaying}"
                                Orientation="Horizontal"
                                Spacing="4">
                        <Border Width="4" Height="16" Background="White" CornerRadius="1" />
                        <Border Width="4" Height="16" Background="White" CornerRadius="1" />
                    </StackPanel>
                </Panel>
            </Button>

            <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="{Binding CurrentTimeDisplay}" Classes="player-time" />
                <Border Grid.Column="1"
                        x:Name="TrackBorder"
                        Classes="player-bar-track"
                        Background="{DynamicResource TranscribaBorder}"
                        Height="4"
                        MinWidth="200"
                        PointerPressed="OnTrackPointerPressed">
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent}"
                                 Height="4"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TranscribaAccent}" />
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding TotalTimeDisplay}" Classes="player-time" />
            </Grid>

            <Button Grid.Column="2"
                    Classes="player-speed"
                    Content="{Binding SpeedLabel}"
                    Command="{Binding CycleSpeedCommand}" />

            <StackPanel Grid.Column="3"
                        Classes="player-volume"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <Path Width="16"
                      Height="16"
                      Stretch="Uniform"
                      Data="M11 5 L6 9 H2 V15 H6 L11 19 V5 Z M15.54 8.46 A5 5 0 0 1 16 12 A5 5 0 0 1 15.54 15.54"
                      Stroke="{DynamicResource TranscribaMuted}"
                      StrokeThickness="1.5"
                      Fill="Transparent" />
                <Slider Minimum="0"
                        Maximum="100"
                        Width="60"
                        Value="{Binding Volume}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
