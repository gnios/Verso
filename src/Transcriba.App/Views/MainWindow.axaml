<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Transcriba.App.ViewModels"
        xmlns:local="using:Transcriba.App"
        x:Class="Transcriba.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Transcriba"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource TranscribaBg}">
    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0"
                Background="{DynamicResource TranscribaSurface}"
                BorderBrush="{DynamicResource TranscribaBorder}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top"
                      Margin="14,12,14,6"
                      ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="📝"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Transcriba"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TranscribaFg}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="{DynamicResource TranscribaRadius}"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip.Tip="Alternar tema">
                        <TextBlock Text="{Binding ThemeIcon}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}"
                        Background="{DynamicResource TranscribaBg}">
            <ContentControl.ContentTemplate>
                <local:ViewLocator />
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
