<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Transcriba.App.ViewModels"
        xmlns:views="using:Transcriba.App.Views"
        xmlns:local="using:Transcriba.App"
        x:Class="Transcriba.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Transcriba"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource TranscribaBg}">
    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0"
                Background="{DynamicResource TranscribaSurface}"
                BorderBrush="{DynamicResource TranscribaBorder}"
                BorderThickness="0,0,1,0">
            <views:SidebarView DataContext="{Binding Sidebar}" />
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}"
                        Background="{DynamicResource TranscribaBg}">
            <ContentControl.ContentTemplate>
                <local:ViewLocator />
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
