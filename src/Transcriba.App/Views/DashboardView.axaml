<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             x:Class="Transcriba.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,40,56,32" Spacing="0">
            <StackPanel Classes="screen-header" Spacing="4">
                <TextBlock Text="Biblioteca" Classes="screen-title" />
                <TextBlock Text="Gerencie suas transcrições e pesquisas"
                           Classes="screen-subtitle" />
            </StackPanel>

            <StackPanel Classes="dash-toolbar" Orientation="Horizontal" Spacing="10">
                <Button Classes="dash-filter"
                        Classes.active="{Binding IsAllFilterActive}"
                        Command="{Binding SetAllFilterCommand}"
                        Content="Todas" />
                <Button Classes="dash-filter"
                        Classes.active="{Binding IsProgressFilterActive}"
                        Command="{Binding SetProgressFilterCommand}"
                        Content="Em andamento" />
                <Button Classes="dash-filter"
                        Classes.active="{Binding IsDoneFilterActive}"
                        Command="{Binding SetDoneFilterCommand}"
                        Content="Concluídas" />
                <TextBox Classes="dash-search"
                         Text="{Binding SearchText}"
                         PlaceholderText="Buscar por título ou conteúdo…" />
            </StackPanel>

            <TextBlock Text="Nenhuma transcrição encontrada."
                       Classes="dash-empty"
                       IsVisible="{Binding IsEmpty}" />

            <ItemsControl ItemsSource="{Binding Cards}"
                          IsVisible="{Binding !IsEmpty}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TranscriptionCardViewModel">
                        <Button Classes="dash-card"
                                Command="{Binding OpenCommand}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                            <Button.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Excluir"
                                              Command="{Binding DeleteCommand}"
                                              IsVisible="{Binding CanDelete}" />
                                </MenuFlyout>
                            </Button.ContextFlyout>
                            <StackPanel Spacing="0">
                                <TextBlock Classes="dash-card-title">
                                    <Run Text="{Binding Icon}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding Title}" />
                                </TextBlock>

                                <TextBlock Text="{Binding Preview}"
                                           Classes="dash-card-preview"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Classes="dash-card-error"
                                           IsVisible="{Binding IsError}" />

                                <ItemsControl ItemsSource="{Binding Tags}"
                                              Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TranscriptionCardTagViewModel">
                                            <Border Classes="tag"
                                                    Classes.tag-blue="{Binding IsBlue}"
                                                    Classes.tag-green="{Binding IsGreen}"
                                                    Classes.tag-yellow="{Binding IsYellow}"
                                                    Classes.tag-red="{Binding IsRed}"
                                                    Classes.tag-purple="{Binding IsPurple}"
                                                    Classes.tag-orange="{Binding IsOrange}"
                                                    Classes.tag-pink="{Binding IsPink}"
                                                    Classes.tag-teal="{Binding IsTeal}"
                                                    Margin="0,0,4,4">
                                                <TextBlock Text="{Binding Name}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Classes="dash-card-meta"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Border Classes="status-badge status-progress"
                                            IsVisible="{Binding IsInProgress}">
                                        <TextBlock Text="{Binding StatusLabel}" />
                                    </Border>
                                    <Border Classes="status-badge status-done"
                                            IsVisible="{Binding IsDone}">
                                        <TextBlock Text="{Binding StatusLabel}" />
                                    </Border>
                                    <Border Classes="status-badge status-error"
                                            IsVisible="{Binding IsError}">
                                        <TextBlock Text="{Binding StatusLabel}" />
                                    </Border>
                                    <Button Classes="dash-retry-btn"
                                            Content="Tentar novamente"
                                            Command="{Binding RetryCommand}"
                                            IsVisible="{Binding CanRetry}" />
                                    <TextBlock Text="{Binding Date}" />
                                    <TextBlock Text="·"
                                               Foreground="{DynamicResource TranscribaMuted}" />
                                    <TextBlock Text="{Binding Duration}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
