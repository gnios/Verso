<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             x:Class="Transcriba.App.Views.SpeakerDropdown"
             x:DataType="vm:SpeakerDropdownViewModel">
    <Border Classes="speaker-dropdown"
            Classes.open="{Binding IsOpen}"
            IsVisible="{Binding IsOpen}">
        <StackPanel>
            <TextBlock Text="Locutores" Classes="speaker-dropdown-title" />

            <ItemsControl ItemsSource="{Binding Speakers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpeakerOptionViewModel">
                        <Button Classes="speaker-option"
                                Classes.active="{Binding IsActive}"
                                Command="{Binding SelectCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{Binding ColorHex}" />
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="✓"
                                           IsVisible="{Binding IsActive}"
                                           Foreground="{DynamicResource TranscribaAccent}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="speaker-divider" Height="1" Margin="4,4" />

            <Grid Classes="speaker-new-row" ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding NewSpeakerName}"
                         PlaceholderText="Novo locutor…" />
                <Button Grid.Column="1"
                        Content="Adicionar"
                        Command="{Binding AddNewSpeakerCommand}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
