<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Transcriba.App.App"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Transcriba.App/Styles/TranscribaTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Button.sidebar-logo">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,4,6,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
        </Style>
        <Style Selector="Button.sidebar-logo:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
        </Style>

        <Style Selector="Button.sidebar-theme-btn">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>
        <Style Selector="Button.sidebar-theme-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
        </Style>

        <Style Selector="Button.sidebar-new">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.sidebar-new:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentHover}" />
        </Style>

        <Style Selector="Button.sidebar-dropdown-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,8,10,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.sidebar-dropdown-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
        </Style>

        <Style Selector="TextBlock.sidebar-section-title">
            <Setter Property="Padding" Value="14,8,14,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
            <Setter Property="LetterSpacing" Value="0.6" />
        </Style>

        <Style Selector="Button.sidebar-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,4,14,4" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.sidebar-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
        </Style>

        <Style Selector="Button.sidebar-trans-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="Padding" Value="3,3,14,3" />
            <Setter Property="Margin" Value="24,0,0,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.sidebar-trans-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
        </Style>

        <Style Selector="TextBlock.sidebar-icon">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="16" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.page-icon">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Width" Value="18" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.chevron">
            <Setter Property="Width" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
            <Setter Property="RenderTransform" Value="rotate(0deg)" />
        </Style>
        <Style Selector="TextBlock.chevron.expanded">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>

        <Style Selector="Border.sidebar-badge">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
            <Setter Property="CornerRadius" Value="99" />
            <Setter Property="Padding" Value="7,1" />
        </Style>
        <Style Selector="Border.sidebar-badge TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.screen-title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
            <Setter Property="LetterSpacing" Value="-0.1" />
        </Style>
        <Style Selector="TextBlock.screen-subtitle">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
        </Style>
        <Style Selector="StackPanel.screen-header">
            <Setter Property="Margin" Value="0,0,0,28" />
        </Style>

        <Style Selector="StackPanel.dash-toolbar">
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
        <Style Selector="Button.dash-filter">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="{DynamicResource TranscribaSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.dash-filter:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorderDark}" />
        </Style>
        <Style Selector="Button.dash-filter.active">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccent}" />
        </Style>

        <Style Selector="TextBox.dash-search">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="{DynamicResource TranscribaBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.dash-search:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaAccent}" />
        </Style>

        <Style Selector="TextBlock.dash-empty">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,48" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="Button.dash-card">
            <Setter Property="Width" Value="300" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Background" Value="{DynamicResource TranscribaBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusLg}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.dash-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorderDark}" />
        </Style>

        <Style Selector="TextBlock.dash-card-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.dash-card-preview">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="StackPanel.dash-card-meta TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>

        <Style Selector="Border.tag">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="CornerRadius" Value="99" />
        </Style>
        <Style Selector="Border.tag TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.tag-blue">
            <Setter Property="Background" Value="{StaticResource TagBlueLight}" />
        </Style>
        <Style Selector="Border.tag-blue TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagBlue}" />
        </Style>
        <Style Selector="Border.tag-green">
            <Setter Property="Background" Value="{StaticResource TagGreenLight}" />
        </Style>
        <Style Selector="Border.tag-green TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagGreen}" />
        </Style>
        <Style Selector="Border.tag-yellow">
            <Setter Property="Background" Value="{StaticResource TagYellowLight}" />
        </Style>
        <Style Selector="Border.tag-yellow TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagYellow}" />
        </Style>
        <Style Selector="Border.tag-red">
            <Setter Property="Background" Value="{StaticResource TagRedLight}" />
        </Style>
        <Style Selector="Border.tag-red TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagRed}" />
        </Style>
        <Style Selector="Border.tag-purple">
            <Setter Property="Background" Value="{StaticResource TagPurpleLight}" />
        </Style>
        <Style Selector="Border.tag-purple TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagPurple}" />
        </Style>
        <Style Selector="Border.tag-orange">
            <Setter Property="Background" Value="{StaticResource TagOrangeLight}" />
        </Style>
        <Style Selector="Border.tag-orange TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagOrange}" />
        </Style>
        <Style Selector="Border.tag-pink">
            <Setter Property="Background" Value="{StaticResource TagPinkLight}" />
        </Style>
        <Style Selector="Border.tag-pink TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagPink}" />
        </Style>
        <Style Selector="Border.tag-teal">
            <Setter Property="Background" Value="{StaticResource TagTealLight}" />
        </Style>
        <Style Selector="Border.tag-teal TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagTeal}" />
        </Style>

        <Style Selector="Border.status-badge">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="CornerRadius" Value="99" />
        </Style>
        <Style Selector="Border.status-badge TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.status-progress">
            <Setter Property="Background" Value="{StaticResource TagYellowLight}" />
        </Style>
        <Style Selector="Border.status-progress TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagYellow}" />
        </Style>
        <Style Selector="Border.status-done">
            <Setter Property="Background" Value="{StaticResource TagGreenLight}" />
        </Style>
        <Style Selector="Border.status-done TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagGreen}" />
        </Style>
        <Style Selector="Border.status-error">
            <Setter Property="Background" Value="{StaticResource TagRedLight}" />
        </Style>
        <Style Selector="Border.status-error TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TagRed}" />
        </Style>
        <Style Selector="Button.dash-retry-btn">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.dash-retry-btn:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccentHover}" />
        </Style>
        <Style Selector="TextBlock.dash-card-error">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TagRed}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="Button.breadcrumb-link">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.breadcrumb-link:pointerover">
            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        </Style>

        <Style Selector="StackPanel.editor-breadcrumb">
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style Selector="StackPanel.page-header">
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
        <Style Selector="Border.page-header-icon">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusLg}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.page-header-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
        </Style>
        <Style Selector="TextBlock.page-header-desc">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>

        <Style Selector="StackPanel.research-section">
            <Setter Property="Margin" Value="0,0,0,28" />
        </Style>
        <Style Selector="Grid.research-section-head">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.research-section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
            <Setter Property="LetterSpacing" Value="0.6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.research-add-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,4,10,4" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.research-add-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
        </Style>

        <Style Selector="ItemsControl.research-list">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button.research-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,10,14,10" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusMd}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.research-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
        </Style>
        <Style Selector="Border.research-item-icon">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.research-item-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
        </Style>
        <Style Selector="StackPanel.research-item-sub TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>
        <Style Selector="ItemsControl.research-item-right">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.upload-zone">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusLg}" />
            <Setter Property="Padding" Value="48,40" />
            <Setter Property="Margin" Value="0,0,0,28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.upload-zone:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
        </Style>
        <Style Selector="Border.upload-zone.dragover">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
        </Style>
        <Style Selector="TextBlock.upload-zone-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.upload-zone-sub">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.upload-file-info">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurface}" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusMd}" />
            <Setter Property="Padding" Value="14,18" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
        <Style Selector="TextBlock.upload-file-name">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
        </Style>
        <Style Selector="TextBlock.upload-file-size">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>
        <Style Selector="TextBlock.upload-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="ComboBox.upload-select">
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Background" Value="{DynamicResource TranscribaBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Grid.upload-form">
            <Setter Property="MaxWidth" Value="560" />
        </Style>
        <Style Selector="Button.upload-btn">
            <Setter Property="Padding" Value="10,28" />
            <Setter Property="Margin" Value="0,20,0,0" />
            <Setter Property="Background" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.upload-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentHover}" />
        </Style>
        <Style Selector="Button.upload-btn:disabled">
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style Selector="TextBlock.upload-error">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TagRed}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style Selector="Button.icon-picker-item">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadius}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon-picker-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurfaceHover}" />
        </Style>
        <Style Selector="Button.icon-picker-item.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaAccent}" />
            <Setter Property="Background" Value="{DynamicResource TranscribaAccentLight}" />
        </Style>
        <Style Selector="Button.icon-picker-item.none-icon TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaMuted}" />
        </Style>
        <Style Selector="Button.icon-picker-item:not(.none-icon) TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style Selector="Button.color-picker-item">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.color-picker-item:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.15)" />
        </Style>
        <Style Selector="Button.color-picker-item.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource TranscribaFg}" />
        </Style>

        <Style Selector="TextBlock.modal-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFg}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style Selector="TextBlock.picker-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TranscribaFgSecondary}" />
            <Setter Property="LetterSpacing" Value="0.4" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="Border.icon-preview">
            <Setter Property="Background" Value="{DynamicResource TranscribaSurface}" />
            <Setter Property="CornerRadius" Value="{DynamicResource TranscribaRadiusMd}" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style Selector="Border.icon-preview-emoji">
