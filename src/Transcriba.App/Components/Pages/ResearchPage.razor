@*
    Página de pesquisa/tese (T61), reaproveitando `ResearchPageViewModel` — fiel às classes
    `.research-*`/`.page-header`/`.editor-breadcrumb` do protótipo
    (transcriba-v2-icons-transcriptions.html, seção `#screen-research`/`renderResearchPage`).

    `ResearchPageViewModel` é registrado como Transient (ver `AppServiceCollectionExtensions`):
    cada navegação para `ScreenKey.Research` resolve/Initialize uma instância nova via
    `NavigationService`. Por isso este componente recebe o ViewModel como [Parameter] (via
    `NavigationService.CurrentViewModel`, repassado pela integração central da shell) em vez de
    `@@inject` — o mesmo padrão vale para as demais telas transient (Dashboard, Upload, Editor,
    Settings).

    Exclusão (T68): a versão Avalonia original (`ResearchPageView.axaml`) usava `ContextFlyout`
    (menu de clique direito) tanto para "Excluir pesquisa" (no ícone do header) quanto para
    "Excluir" por transcrição (no item da lista) — Blazor/HTML não tem um equivalente direto sem
    JS interop extra, então aqui reaproveitamos o mesmo padrão de botão de ação visível ao lado do
    conteúdo já adotado por `TranscriptionCard.razor` (`.dash-card-action`/`-danger`), em vez de
    introduzir um menu de contexto novo só para isso. Ambos os comandos (`DeleteResearchCommand`/
    `TranscriptionCardViewModel.DeleteCommand`) já existiam e já chamavam `IConfirmationService` —
    só faltava o wiring na view.
*@
@implements IDisposable

<section class="screen active">
    <div class="screen-header">
        <div class="editor-breadcrumb">
            <a href="#" @onclick="() => ViewModel.NavigateDashboardCommand.Execute(null)" @onclick:preventDefault="true">Biblioteca</a>
            &nbsp;→&nbsp; @ViewModel.Title
        </div>
        <div class="page-header">
            <div class="page-header-icon" style="background:var(--@(ViewModel.ColorName)-light)">@ViewModel.Icon</div>
            <div class="page-header-text">
                <h2>@ViewModel.Title</h2>
                <p>@ViewModel.Description</p>
            </div>
            <button class="dash-card-action dash-card-action-danger" style="margin-left:auto" title="Excluir pesquisa" @onclick="() => ViewModel.DeleteResearchCommand.Execute(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                Excluir pesquisa
            </button>
        </div>
    </div>

    <div class="research-section">
        <div class="research-section-head">
            <h3>Transcrições</h3>
            <button class="research-add-btn" @onclick="() => ViewModel.AddTranscriptionCommand.Execute(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
                Adicionar
            </button>
        </div>

        <div class="dash-toolbar">
            <button class="dash-filter @(ViewModel.IsAllFilterActive ? "active" : "")" @onclick="() => ViewModel.SetAllFilterCommand.Execute(null)">Todas</button>
            <button class="dash-filter @(ViewModel.IsProgressFilterActive ? "active" : "")" @onclick="() => ViewModel.SetProgressFilterCommand.Execute(null)">Em andamento</button>
            <button class="dash-filter @(ViewModel.IsDoneFilterActive ? "active" : "")" @onclick="() => ViewModel.SetDoneFilterCommand.Execute(null)">Concluídas</button>
            <input class="dash-search" type="text" placeholder="Buscar por título ou conteúdo…" value="@ViewModel.SearchText" @oninput="OnSearchInput" />
        </div>
        @if (ViewModel.IsEmpty)
        {
            <div style="grid-column:1/-1;text-align:center;padding:48px;color:var(--muted)">Nenhuma transcrição encontrada.</div>
        }
        else
        {
            <div class="dash-grid">
                @foreach (var card in ViewModel.Transcriptions)
                {
                    <TranscriptionCard @key="card.Id" ViewModel="card" />
                }
            </div>
        }
    </div>
</section>

@code {
    private ResearchPageViewModel? _observedViewModel;

    [Parameter, EditorRequired]
    public required ResearchPageViewModel ViewModel { get; set; }

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_observedViewModel, ViewModel))
        {
            return;
        }

        Unsubscribe();
        _observedViewModel = ViewModel;
        ViewModel.PropertyChanged += OnViewModelChanged;
        ViewModel.Transcriptions.CollectionChanged += OnCollectionChanged;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        ViewModel.SearchText = e.Value?.ToString() ?? "";
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnCollectionChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void Unsubscribe()
    {
        if (_observedViewModel is null)
        {
            return;
        }

        _observedViewModel.PropertyChanged -= OnViewModelChanged;
        _observedViewModel.Transcriptions.CollectionChanged -= OnCollectionChanged;
    }

    public void Dispose() => Unsubscribe();
}
