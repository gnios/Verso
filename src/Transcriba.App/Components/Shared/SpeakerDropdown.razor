@*
    Dropdown de atribuição de locutor ao segmento ativo (T64), reaproveitando
    `SpeakerDropdownViewModel` — fiel ao `#speaker-dropdown` do protótipo
    (transcriba-v2-icons-transcriptions.html).

    Posicionado como filho relativo do botão "Locutor" na toolbar do editor
    (`.speaker-dropdown` comRepositioned via CSS existente).
*@
@implements IDisposable

<div class="speaker-dropdown @(ViewModel.IsOpen ? "open" : "")">
    <div class="speaker-dropdown-title">Selecionar locutor</div>
    @foreach (var speaker in ViewModel.Speakers)
    {
        <div class="speaker-option @(speaker.IsActive ? "active" : "")"
             @onclick="() => speaker.SelectCommand.Execute(null)">
            <span class="sp-dot" style="background:@speaker.ColorHex"></span>
            @speaker.Name
        </div>
    }
    <div class="speaker-divider"></div>
    <div class="speaker-new-row">
        <input type="text" placeholder="Novo locutor…" value="@ViewModel.NewSpeakerName"
               @oninput="OnNewSpeakerInput" @onkeydown="OnNewSpeakerKeyDown" />
        <button type="button" disabled="@(!ViewModel.CanAssign)" @onclick="async () => await ViewModel.AddNewSpeakerCommand.ExecuteAsync(null)">Adicionar</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public SpeakerDropdownViewModel ViewModel { get; set; } = null!;

    private SpeakerDropdownViewModel? _subscribed;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_subscribed, ViewModel))
        {
            return;
        }

        Unsubscribe();
        _subscribed = ViewModel;
        ViewModel.PropertyChanged += OnViewModelChanged;
        ViewModel.Speakers.CollectionChanged += OnSpeakersChanged;
        SubscribeSpeakerOptions();
    }

    private void SubscribeSpeakerOptions()
    {
        foreach (var speaker in ViewModel.Speakers)
        {
            speaker.PropertyChanged += OnSpeakerOptionChanged;
        }
    }

    private void UnsubscribeSpeakerOptions()
    {
        foreach (var speaker in ViewModel.Speakers)
        {
            speaker.PropertyChanged -= OnSpeakerOptionChanged;
        }
    }

    private void OnSpeakerOptionChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnNewSpeakerInput(ChangeEventArgs e) =>
        ViewModel.NewSpeakerName = e.Value?.ToString() ?? "";

    private async Task OnNewSpeakerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && ViewModel.CanAssign)
        {
            await ViewModel.AddNewSpeakerCommand.ExecuteAsync(null);
        }
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnSpeakersChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        UnsubscribeSpeakerOptions();
        SubscribeSpeakerOptions();
        InvokeAsync(StateHasChanged);
    }

    private void Unsubscribe()
    {
        if (_subscribed is null)
        {
            return;
        }

        _subscribed.PropertyChanged -= OnViewModelChanged;
        _subscribed.Speakers.CollectionChanged -= OnSpeakersChanged;
        UnsubscribeSpeakerOptions();
    }

    public void Dispose() => Unsubscribe();
}
