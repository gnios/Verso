@*
    Modal "Nova pesquisa / tese" (T58), reaproveitando NewPageModalViewModel.

    A criação de transcrição avulsa (com arquivo, tags, ícone e nome) foi migrada para a
    tela Upload (Upload.razor/UploadViewModel), que agora oferece as mesmas opções que
    este modal oferecia no modo transcrição. Este modal atende apenas a criação de
    pesquisas, então o seletor de modo, o campo de tags e o seletor de arquivo foram
    removidos (clean cutover) — sobram ícone, cor, preview e título, fiel às classes
    `.modal-overlay`/`.modal`/`.icon-picker-*`/`.color-picker-*`/`.icon-preview` do
    protótipo (transcriba-v2-icons-transcriptions.html).

    Cor do preview: em vez das flags IsBlue/IsGreen/... (herdadas da versão Avalonia,
    úteis para triggers de Style em XAML), usamos aqui a interpolação direta
    `var(--{nome}-light)` sobre as custom properties já existentes no app.css — mesmo
    espírito do `tag-@@research.ColorName` já usado em Sidebar.razor.
*@
@implements IDisposable
@inject NewPageModalViewModel ViewModel

<div class="modal-overlay @(ViewModel.IsOpen ? "open" : "")">
    <div class="modal modal-new-page">
        <div class="modal-title">@ViewModel.ModalTitle</div>

        @if (!string.IsNullOrWhiteSpace(ViewModel.ValidationError))
        {
            <div class="upload-error">@ViewModel.ValidationError</div>
        }

        <div class="icon-picker-label">Ícone</div>
        <IconPicker ViewModel="ViewModel.IconPicker" />

        <div class="color-picker-label">Cor</div>
        <ColorPicker ViewModel="ViewModel.ColorPicker" />

        <div class="icon-preview">
            <div class="icon-preview-emoji" style="background:var(--@(ViewModel.PreviewColorName)-light)">@ViewModel.PreviewIcon</div>
            <div class="icon-preview-text">@ViewModel.PreviewTitle</div>
        </div>

        <div class="modal-field">
            <label>Título</label>
            <input type="text" value="@ViewModel.Title" @oninput="OnTitleInput"
                   placeholder="Ex.: Mobilidade Urbana — Tese 2025" @onkeydown="OnTitleKeyDown" />
        </div>

        <div class="modal-actions">
            <button class="modal-cancel" @onclick="() => ViewModel.CancelCommand.Execute(null)">Cancelar</button>
            <button class="modal-confirm" disabled="@(!ViewModel.CanConfirm)" @onclick="async () => await ViewModel.ConfirmCommand.ExecuteAsync(null)">@ViewModel.ConfirmButtonLabel</button>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnViewModelChanged;
    }

    private void OnTitleInput(ChangeEventArgs e) =>
        ViewModel.Title = e.Value?.ToString() ?? "";

    private async Task OnTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && ViewModel.CanConfirm)
        {
            await ViewModel.ConfirmCommand.ExecuteAsync(null);
        }
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelChanged;
    }
}