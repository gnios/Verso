<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Transcriba.App.ViewModels"
             x:Class="Transcriba.App.Controls.IconPicker"
             x:DataType="vm:IconPickerViewModel">
    <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="8" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:IconPickerItemViewModel">
                <Button Classes="icon-picker-item"
                        Classes.selected="{Binding IsSelected}"
                        Classes.none-icon="{Binding IsNoIconOption}"
                        Command="{Binding SelectCommand}">
                    <TextBlock Text="{Binding DisplayText}" />
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
