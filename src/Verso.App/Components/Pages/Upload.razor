@*
    Upload — nova transcrição.
    Sem arquivo: só a zona de áudio/vídeo.
    Com arquivo: identidade → precisão → idioma → arquivo → iniciar.
*@
@implements IDisposable
@using System.Linq
@using Verso.App.Components.Shared
@inject IFileOpenService FileOpenService

<section class="screen active">
    @if (!string.IsNullOrWhiteSpace(ViewModel.ValidationError))
    {
        <div class="upload-error">@ViewModel.ValidationError</div>
    }

    @if (!ViewModel.HasSelectedFile)
    {
        <div class="upload-audio-section">
            <label class="upload-label">Arquivo de áudio ou vídeo</label>
            <div class="upload-zone @(ViewModel.IsDragOver ? "dragover" : "")"
                 @onclick="OnZoneClickedAsync"
                 @ondragover="OnDragOver" @ondragover:preventDefault="true"
                 @ondragleave="OnDragLeave"
                 @ondrop="OnDrop" @ondrop:preventDefault="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                <div class="upload-zone-title">Arraste um arquivo aqui</div>
                <div class="upload-zone-sub">@ViewModel.SupportedFormatsLabel</div>
            </div>
        </div>
    }
    else
    {
        <div class="upload-identity">
            <div class="editor-title-row" style="position:relative">
                <div class="editor-page-icon @(ViewModel.HasIcon ? "has-icon" : "")"
                     title="Clique para trocar ícone"
                     @onclick="() => ViewModel.ToggleIconPickerCommand.Execute(null)">
                    @(ViewModel.HasIcon ? ViewModel.Icon : "+")
                </div>
                <input type="text" class="editor-title-input" value="@ViewModel.Title"
                       placeholder="Título da transcrição"
                       @oninput="OnTitleInput" />
                <div class="icon-popup @(ViewModel.IsIconPickerOpen ? "open" : "")">
                    <div class="icon-popup-title">Ícone da transcrição</div>
                    <IconPicker ViewModel="ViewModel.IconPicker" />
                    <div style="display:flex;gap:6px;justify-content:flex-end;margin-top:8px">
                        <button type="button" class="upload-icon-done"
                                @onclick="() => ViewModel.CloseIconPickerCommand.Execute(null)">Feito</button>
                    </div>
                </div>
            </div>

            <div class="upload-meta">
                <FolderCombobox Options="ViewModel.FolderOptions"
                                SelectedId="ViewModel.SelectedFolderId"
                                OnSelected="OnFolderSelected" />
                <span class="editor-meta-dot"></span>
                <input type="text" class="upload-tags-input" value="@ViewModel.TagsText"
                       @oninput="OnTagsInput"
                       placeholder="Tags (vírgula)" />
            </div>
        </div>

        <div class="upload-precision">
            <label class="upload-label">Precisão da transcrição</label>
            <PrecisionProfileCards Options="ViewModel.ModelOptions"
                                  Selected="ViewModel.SelectedModelOption"
                                  SelectedChanged="OnPrecisionSelected" />
        </div>

        <div class="upload-form upload-form-single">
            <div>
                <label class="upload-label">Idioma</label>
                <select class="upload-select" value="@ViewModel.SelectedLanguageOption?.Code" @onchange="OnLanguageChanged">
                    @foreach (var option in ViewModel.LanguageOptions)
                    {
                        <option value="@option.Code">@option.Label</option>
                    }
                </select>
            </div>
        </div>

        <div class="upload-audio-section">
            <label class="upload-label">Arquivo de áudio ou vídeo</label>
            <div class="upload-file-info show">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                <div>
                    <div class="upload-file-name">@ViewModel.SelectedFileName</div>
                    <div class="upload-file-size">@ViewModel.SelectedFileSize</div>
                </div>
                <button type="button" class="upload-file-clear" title="Remover arquivo" @onclick="() => ViewModel.ClearFileCommand.Execute(null)">✕</button>
            </div>
        </div>

        <button type="button" class="upload-btn" disabled="@(!ViewModel.CanStart)" @onclick="() => ViewModel.StartTranscriptionCommand.ExecuteAsync(null)">
            @(ViewModel.IsStarting ? "Enviando…" : "Iniciar transcrição")
        </button>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public required UploadViewModel ViewModel { get; set; }

    private UploadViewModel? _subscribed;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_subscribed, ViewModel))
        {
            return;
        }

        Unsubscribe();
        _subscribed = ViewModel;
        ViewModel.PropertyChanged += OnViewModelChanged;
    }

    private async Task OnZoneClickedAsync()
    {
        var path = await FileOpenService.PickMediaFileAsync();
        if (!string.IsNullOrWhiteSpace(path))
        {
            ViewModel.TrySelectFile(path);
        }
    }

    private void OnDragOver() => ViewModel.IsDragOver = true;

    private void OnDragLeave() => ViewModel.ClearDragOver();

    private void OnDrop() => ViewModel.ClearDragOver();

    private void OnLanguageChanged(ChangeEventArgs e)
    {
        var code = e.Value?.ToString();
        var option = ViewModel.LanguageOptions.FirstOrDefault(o => o.Code == code);
        if (option is not null)
        {
            ViewModel.SelectedLanguageOption = option;
        }
    }

    private void OnPrecisionSelected(ModelOptionViewModel option) =>
        ViewModel.SelectedModelOption = option;

    private void OnFolderSelected(int? folderId)
    {
        ViewModel.SelectedFolder = ViewModel.FolderOptions.FirstOrDefault(o => o.Id == folderId)
            ?? ViewModel.FolderOptions.FirstOrDefault(o => o.Id is null);
    }

    private void OnTitleInput(ChangeEventArgs e) =>
        ViewModel.Title = e.Value?.ToString() ?? "";

    private void OnTagsInput(ChangeEventArgs e) =>
        ViewModel.TagsText = e.Value?.ToString() ?? "";

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void Unsubscribe()
    {
        if (_subscribed is null)
        {
            return;
        }

        _subscribed.PropertyChanged -= OnViewModelChanged;
    }

    public void Dispose() => Unsubscribe();
}
