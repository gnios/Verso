@*
    Tela de Configurações (T67) reaproveitando o SettingsViewModel real (perfil, idioma padrão,
    identificar locutores, precisão por cartões, dispositivo de execução em Avançado) — fiel às classes
    CSS `.settings-*`/`.toggle`/`.screen-*` do protótipo (transcriba-v2-icons-transcriptions.html).

    ViewModel recebido via [Parameter] (e não @inject) porque SettingsViewModel é Transient
    (AppServiceCollectionExtensions) e a instância viva é a resolvida pelo NavigationService em
    NavigationService.CurrentViewModel — mesmo padrão que os demais componentes de página
    (Dashboard/Upload/Editor) devem seguir quando o MainLayout passar a despachar por tela.

    O toggle de tema reaproveita o ThemeService singleton (mesmo serviço já usado pelo
    Sidebar.razor para o botão de tema do cabeçalho) em vez de duplicar lógica de persistência
    no SettingsViewModel — ThemeService.ToggleAsync já persiste via SettingsService.
*@
@implements IDisposable
@inject ThemeService ThemeService
@using System.ComponentModel
@using System.Linq
@using Verso.App.Components.Shared
@using Verso.Core.Data.Entities
@using Verso.App.ViewModels

<section class="screen active">
    <div class="screen-header">
        <h1 class="screen-title">Configurações</h1>
        <p class="screen-subtitle">Gerencie seu perfil e preferências</p>
    </div>

    <div class="settings-section">
        <div class="settings-section-title">Perfil</div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Nome</div>
            </div>
            <input type="text" value="@ViewModel.Name" @onchange="OnNameChanged" />
        </div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">E-mail</div>
            </div>
            <input type="email" value="@ViewModel.Email" @onchange="OnEmailChanged" />
        </div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Instituição</div>
            </div>
            <input type="text" value="@ViewModel.Institution" @onchange="OnInstitutionChanged" />
        </div>
    </div>

    <div class="settings-section">
        <div class="settings-section-title">Transcrição</div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Idioma</div>
            </div>
            <select value="@ViewModel.SelectedLanguageOption?.Code" @onchange="OnLanguageChanged">
                @foreach (var option in ViewModel.LanguageOptions)
                {
                    <option value="@option.Code">@option.Label</option>
                }
            </select>
        </div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Identificar locutores</div>
                <div class="settings-row-sub">Detecta vozes e atribui rótulos</div>
            </div>
            <div class="toggle @(ViewModel.IdentifySpeakersDefault ? "on" : "")" @onclick="ToggleIdentifySpeakers"></div>
        </div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Transcrição ao vivo</div>
                <div class="settings-row-sub">Em breve — ainda não disponível nesta versão</div>
            </div>
            <div class="toggle disabled @(ViewModel.LiveTranscriptionEnabled ? "on" : "")"
                 title="Em breve"
                 aria-disabled="true"></div>
        </div>
    </div>

    <div class="settings-section">
        <div class="settings-section-title">Precisão da transcrição</div>
        <PrecisionProfileCards Options="ViewModel.ModelOptions"
                              Selected="ViewModel.SelectedModelOption"
                              Recommended="ViewModel.RecommendedModelOption"
                              SelectedChanged="OnPrecisionSelected" />
        @if (ViewModel.RecommendedModelOption is not null)
        {
            <div class="settings-recommendation">
                <div class="settings-recommendation-title">
                    Recomendado para seu computador
                    <span class="settings-ram-hint">(@(ViewModel.DetectedRamGb) GB)</span>
                </div>
                <div class="settings-recommendation-body">
                    <span class="rec-model">@ViewModel.RecommendedModelOption?.Label · @ViewModel.RecommendedModelOption?.SpeedHint</span>
                    <span class="settings-recommendation-reason">@ViewModel.ModelRecommendationReason</span>
                </div>
                <button type="button" class="settings-recommendation-btn" @onclick="UseRecommended">Usar recomendado</button>
            </div>
        }
    </div>

    <div class="settings-section">
        <div class="settings-section-title">Aparência</div>
        <div class="settings-row">
            <div>
                <div class="settings-row-label">Tema escuro</div>
                <div class="settings-row-sub">Alterna entre tema claro e escuro</div>
            </div>
            <div class="toggle @(ThemeService.IsDark ? "on" : "")" @onclick="ToggleTheme"></div>
        </div>
    </div>

    <div class="settings-section">
        <button type="button" class="settings-advanced-toggle" @onclick="ToggleAdvanced">
            <span>Avançado</span>
            <span class="settings-advanced-chevron @(ViewModel.IsAdvancedExpanded ? "open" : "")">▾</span>
        </button>
        @if (ViewModel.IsAdvancedExpanded)
        {
            <div class="settings-advanced-body">
                <div class="settings-row">
                    <div>
                        <div class="settings-row-label">Dispositivo de execução</div>
                        <div class="settings-row-sub">Deixe em Automático, salvo se precisar forçar CPU ou GPU</div>
                    </div>
                    <select value="@ViewModel.SelectedDeviceOption?.Value" @onchange="OnDeviceChanged">
                        @foreach (var option in ViewModel.DeviceOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>

                <div class="settings-section-title settings-advanced-subtitle">Desenvolvedor</div>
                <div class="settings-row dev-info-row">
                    <div>
                        <div class="settings-row-label">Dispositivo configurado</div>
                        <div class="settings-row-sub">@ViewModel.ConfiguredDeviceLabel</div>
                    </div>
                </div>
                <div class="settings-row dev-info-row">
                    <div>
                        <div class="settings-row-label">Preferência de runtime</div>
                        <div class="settings-row-sub dev-mono">@ViewModel.RuntimePreferenceLabel</div>
                    </div>
                </div>
                <div class="settings-row dev-info-row">
                    <div>
                        <div class="settings-row-label">Runtime em uso</div>
                        <div class="settings-row-sub">
                            @if (ViewModel.IsRuntimeLoaded)
                            {
                                <span class="dev-runtime-badge dev-runtime-@ViewModel.LoadedBackendLabel.ToLower()">
                                    @ViewModel.LoadedRuntimeLabel · @ViewModel.LoadedBackendLabel
                                </span>
                            }
                            else
                            {
                                <span class="dev-runtime-badge dev-runtime-none">Ainda não carregado</span>
                            }
                        </div>
                    </div>
                    <button type="button" class="settings-recommendation-btn" @onclick="VerifyRuntime">Verificar agora</button>
                </div>

                <div class="settings-row dev-info-row dev-stack">
                    <div>
                        <div class="settings-row-label">Placa em uso (backend ativo)</div>
                        <div class="settings-row-sub">
                            <span class="dev-active-gpu">@ViewModel.ActiveGpuLabel</span>
                            @if (!string.IsNullOrEmpty(ViewModel.ActiveGpuSourceLabel) && ViewModel.ActiveGpuSourceLabel != "—")
                            {
                                <span class="dev-active-gpu-source"> · @ViewModel.ActiveGpuSourceLabel</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(ViewModel.ActiveGpuNote))
                        {
                            <div class="dev-message">@ViewModel.ActiveGpuNote</div>
                        }
                    </div>
                </div>

                <div class="settings-row dev-info-row dev-stack">
                    <div>
                        <div class="settings-row-label">Placas de vídeo detectadas</div>
                        @if (ViewModel.Gpus.Count == 0)
                        {
                            <div class="settings-row-sub">Nenhuma placa detectada (WMI indisponível).</div>
                        }
                        else
                        {
                            <ul class="dev-gpu-list">
                                @foreach (var gpu in ViewModel.Gpus)
                                {
                                    <li>
                                        <span class="dev-gpu-kind @gpu.KindLabel.ToLower()">@gpu.KindLabel</span>
                                        <span class="dev-gpu-name">@gpu.Name</span>
                                        <span class="dev-gpu-vendor">@gpu.Vendor · @gpu.RamLabel</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                    <button type="button" class="settings-recommendation-btn" @onclick="RefreshDeveloperInfo">Atualizar</button>
                </div>

                <div class="settings-row dev-info-row dev-stack">
                    <div>
                        <div class="settings-row-label">Arquivo de logs</div>
                        <div class="settings-row-sub dev-mono">@ViewModel.LogDirectoryPath</div>
                        @if (!string.IsNullOrEmpty(ViewModel.DeveloperMessage))
                        {
                            <div class="dev-message">@ViewModel.DeveloperMessage</div>
                        }
                    </div>
                    <button type="button" class="settings-recommendation-btn" @onclick="OpenLogFolder">Abrir pasta</button>
                </div>
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public SettingsViewModel ViewModel { get; set; } = default!;

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnObservedChanged;
        ThemeService.PropertyChanged += OnObservedChanged;
    }

    private void OnNameChanged(ChangeEventArgs e)
    {
        ViewModel.Name = e.Value?.ToString() ?? "";
        ViewModel.SaveProfileCommand.Execute(null);
    }

    private void OnEmailChanged(ChangeEventArgs e)
    {
        ViewModel.Email = e.Value?.ToString() ?? "";
        ViewModel.SaveProfileCommand.Execute(null);
    }

    private void OnInstitutionChanged(ChangeEventArgs e)
    {
        ViewModel.Institution = e.Value?.ToString() ?? "";
        ViewModel.SaveProfileCommand.Execute(null);
    }

    private void OnLanguageChanged(ChangeEventArgs e)
    {
        var code = e.Value?.ToString();
        var option = ViewModel.LanguageOptions.FirstOrDefault(o => o.Code == code);
        if (option is not null)
        {
            ViewModel.SelectedLanguageOption = option;
        }
    }

    private void OnDeviceChanged(ChangeEventArgs e)
    {
        if (!Enum.TryParse<ExecutionDevice>(e.Value?.ToString(), out var device))
        {
            return;
        }

        var option = ViewModel.DeviceOptions.FirstOrDefault(o => o.Value == device);
        if (option is not null)
        {
            ViewModel.SelectedDeviceOption = option;
        }
    }

    private void OnPrecisionSelected(ModelOptionViewModel option) =>
        ViewModel.SelectedModelOption = option;

    private void UseRecommended() => ViewModel.UseRecommendedModelCommand.Execute(null);
    private void ToggleAdvanced() => ViewModel.IsAdvancedExpanded = !ViewModel.IsAdvancedExpanded;
    private void RefreshDeveloperInfo() => ViewModel.RefreshDeveloperInfoCommand.Execute(null);
    private void VerifyRuntime() => ViewModel.VerifyRuntimeCommand.Execute(null);
    private void OpenLogFolder() => ViewModel.OpenLogFolderCommand.Execute(null);
    private void ToggleIdentifySpeakers() => ViewModel.IdentifySpeakersDefault = !ViewModel.IdentifySpeakersDefault;

    private async Task ToggleTheme() => await ThemeService.ToggleAsync();

    private void OnObservedChanged(object? sender, PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnObservedChanged;
        ThemeService.PropertyChanged -= OnObservedChanged;
    }
}
