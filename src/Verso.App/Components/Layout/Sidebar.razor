@*
    Sidebar fixa (260px) reaproveitando o SidebarViewModel real (pastas, tags, contadores
    vindos do SQLite via LibraryService/FolderService) — fiel às classes CSS `.sidebar*` do
    protótipo. Ação principal: "Nova transcrição". Pasta nova fica no "+" da seção Pastas.
*@
@implements IDisposable
@inject SidebarViewModel ViewModel

<aside class="sidebar">
    <div class="sidebar-header">
        <a href="#" class="sidebar-logo" @onclick="() => ViewModel.NavigateDashboardCommand.Execute(null)" @onclick:preventDefault="true">
            <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="2" y="4" width="3" height="16" rx="1.2"/><rect x="6.5" y="10" width="3" height="10" rx="1.2"/><rect x="11" y="15" width="3" height="5" rx="1.2"/><rect x="15.5" y="10" width="3" height="10" rx="1.2"/><rect x="20" y="4" width="3" height="16" rx="1.2"/></svg>
            Verso
        </a>
        <button class="sidebar-theme-btn" title="Alternar tema" @onclick="async () => await ViewModel.ToggleThemeCommand.ExecuteAsync(null)">
            @ViewModel.ThemeIcon
        </button>
    </div>

    <div class="sidebar-actions">
        <button class="sidebar-new" @onclick="() => ViewModel.NewTranscriptionCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" /></svg>
            Nova transcrição
        </button>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">
            <span>Pastas</span>
            <button @onclick="() => ViewModel.NewFolderCommand.Execute(null)" title="Nova pasta">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
            </button>
        </div>
        <div>
            <div class="sidebar-item" @onclick="() => ViewModel.NavigateUnassignedCommand.Execute(null)" title="Transcrições sem pasta associada">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /><line x1="3" y1="3" x2="21" y2="21" /></svg>
                Sem pasta
                <span class="badge">@ViewModel.UnassignedCount</span>
            </div>
            @foreach (var folder in ViewModel.Folders)
            {
                <div class="sidebar-item" @onclick="() => folder.NavigateCommand.Execute(null)" title="@folder.Title">
                    <span class="chevron-toggle" @onclick="() => folder.ToggleExpandCommand.Execute(null)" @onclick:stopPropagation="true">
                        <svg class="chevron @(folder.IsExpanded ? "expanded" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                    </span>
                    <span class="page-icon" style="color:@folder.ColorHex">@folder.Icon</span>
                    @folder.Title
                    <span class="badge">@folder.TranscriptionCount</span>
                </div>
                <div class="sidebar-sub @(folder.IsExpanded ? "" : "collapsed")">
                    @foreach (var transcription in folder.Transcriptions)
                    {
                        <div class="sidebar-trans-item" @onclick="() => transcription.OpenCommand.Execute(null)">
                            @if (!string.IsNullOrEmpty(transcription.Icon))
                            {
                                <span class="trans-icon">@transcription.Icon</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                            }
                            @if (!string.IsNullOrEmpty(transcription.StatusIcon))
                            {
                                <span style="font-size:12px;margin-left:auto">@transcription.StatusIcon</span>
                            }
                            @transcription.Title
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">Transcrições</div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateAllCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
            Todas
            <span class="badge">@ViewModel.TotalCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateInProgressCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
            Em andamento
            <span class="badge">@ViewModel.InProgressCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateDoneCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4 12 14.01l-3-3" /></svg>
            Concluídas
            <span class="badge">@ViewModel.DoneCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateErrorCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M15 9l-6 6M9 9l6 6" /></svg>
            Com erro
            <span class="badge">@ViewModel.ErrorCount</span>
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">Tags</div>
        <div>
            @foreach (var tag in ViewModel.Tags)
            {
                <div class="sidebar-item" @onclick="() => tag.NavigateCommand.Execute(null)">
                    <span class="tag tag-sm tag-@tag.ColorName" style="margin-left:2px">@tag.Name</span>
                    <span style="margin-left:auto;font-size:12px;color:var(--muted)">@tag.Count</span>
                </div>
            }
        </div>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateSettingsCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
            Configurações
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.OpenFeedbackCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /><path d="M8 9h8M8 13h6" /></svg>
            Feedback
        </div>
    </div>
</aside>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += OnViewModelChanged;
        ViewModel.Folders.CollectionChanged += OnCollectionsChanged;
        ViewModel.Tags.CollectionChanged += OnCollectionsChanged;

        // Único load inicial da sidebar (o ctor do singleton não carrega mais).
        await ViewModel.LoadAsync();
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnCollectionsChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelChanged;
        ViewModel.Folders.CollectionChanged -= OnCollectionsChanged;
        ViewModel.Tags.CollectionChanged -= OnCollectionsChanged;
    }
}
