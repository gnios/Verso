@*
    Sidebar fixa (260px) reaproveitando o SidebarViewModel real (pesquisas, tags, contadores
    vindos do SQLite via LibraryService/ResearchService) — fiel às classes CSS `.sidebar*` do
    protótipo (transcriba-v2-icons-transcriptions.html).

    Nota: no protótipo, o `<div class="dropdown">` do menu "Nova" fica aninhado dentro do
    `<button class="sidebar-new">` (o CSS ancora `.dropdown` em `position:relative` do botão).
    Em Blazor isso causaria bubbling do clique nos itens do dropdown até o handler do botão
    (reabrindo o menu que o próprio item acabou de fechar). Por isso o dropdown é colocado aqui
    como irmão do botão, dentro de `.sidebar-actions` (com `position:relative` inline — não há
    classe CSS equivalente já portada para esse contêiner) — mesmas classes, mesma aparência,
    sem o problema de propagação de evento.
*@
@implements IDisposable
@inject SidebarViewModel ViewModel

<aside class="sidebar">
    <div class="sidebar-header">
        <a href="#" class="sidebar-logo" @onclick="() => ViewModel.NavigateDashboardCommand.Execute(null)" @onclick:preventDefault="true">
            <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="2" y="4" width="3" height="16" rx="1.2"/><rect x="6.5" y="10" width="3" height="10" rx="1.2"/><rect x="11" y="15" width="3" height="5" rx="1.2"/><rect x="15.5" y="10" width="3" height="10" rx="1.2"/><rect x="20" y="4" width="3" height="16" rx="1.2"/></svg>
            Verso
        </a>
        <button class="sidebar-theme-btn" title="Alternar tema" @onclick="async () => await ViewModel.ToggleThemeCommand.ExecuteAsync(null)">
            @ViewModel.ThemeIcon
        </button>
    </div>

    <div class="sidebar-search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
        <input type="text" placeholder="Buscar…" value="@ViewModel.SearchText" @oninput="OnSearchInput" />
    </div>

    <div class="sidebar-actions" style="position:relative">
        <button class="sidebar-new" @onclick="() => ViewModel.ToggleNewMenuCommand.Execute(null)" @onclick:stopPropagation="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" /></svg>
            Nova
        </button>
        <div class="dropdown @(ViewModel.IsNewMenuOpen ? "open" : "")">
            <div class="dropdown-item" @onclick="() => ViewModel.NewResearchCommand.Execute(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
                Pesquisa / Tese
            </div>
            <div class="dropdown-item" @onclick="() => ViewModel.NewTranscriptionCommand.Execute(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                Transcrição
            </div>
            <div class="dropdown-item" @onclick="() => ViewModel.NewRecordingCommand.Execute(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" /></svg>
                Gravar agora
            </div>
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">
            <span>Pesquisas</span>
            <button @onclick="() => ViewModel.NewResearchCommand.Execute(null)" title="Nova pesquisa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
            </button>
        </div>
        <div>
            <div class="sidebar-item" @onclick="() => ViewModel.NavigateUnassignedCommand.Execute(null)" title="Transcrições sem pesquisa associada">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /><line x1="3" y1="3" x2="21" y2="21" /></svg>
                Sem pesquisa
                <span class="badge">@ViewModel.UnassignedCount</span>
            </div>
            @foreach (var research in ViewModel.Researches)
            {
                <div class="sidebar-item" @onclick="() => research.NavigateCommand.Execute(null)" title="@research.Title">
                    <span class="chevron-toggle" @onclick="() => research.ToggleExpandCommand.Execute(null)" @onclick:stopPropagation="true">
                        <svg class="chevron @(research.IsExpanded ? "expanded" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                    </span>
                    <span class="page-icon" style="color:@research.ColorHex">@research.Icon</span>
                    @research.Title
                    <span class="badge">@research.TranscriptionCount</span>
                </div>
                <div class="sidebar-sub @(research.IsExpanded ? "" : "collapsed")">
                    @foreach (var transcription in research.Transcriptions)
                    {
                        <div class="sidebar-trans-item" @onclick="() => transcription.OpenCommand.Execute(null)">
                            @if (!string.IsNullOrEmpty(transcription.Icon))
                            {
                                <span class="trans-icon">@transcription.Icon</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                            }
                            @transcription.Title
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">Transcrições</div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateAllCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
            Todas
            <span class="badge">@ViewModel.TotalCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateInProgressCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
            Em andamento
            <span class="badge">@ViewModel.InProgressCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateDoneCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4 12 14.01l-3-3" /></svg>
            Concluídas
            <span class="badge">@ViewModel.DoneCount</span>
        </div>
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateRecordingCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" /></svg>
            Gravar agora
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">Tags</div>
        <div>
            @foreach (var tag in ViewModel.Tags)
            {
                <div class="sidebar-item" @onclick="() => tag.NavigateCommand.Execute(null)">
                    <span class="tag tag-sm tag-@tag.ColorName" style="margin-left:2px">@tag.Name</span>
                    <span style="margin-left:auto;font-size:12px;color:var(--muted)">@tag.Count</span>
                </div>
            }
        </div>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
        <div class="sidebar-item" @onclick="() => ViewModel.NavigateSettingsCommand.Execute(null)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
            Configurações
        </div>
    </div>
</aside>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += OnViewModelChanged;
        ViewModel.Researches.CollectionChanged += OnCollectionsChanged;
        ViewModel.Tags.CollectionChanged += OnCollectionsChanged;

        // O construtor do SidebarViewModel já dispara LoadAsync (fire-and-forget) na primeira
        // resolução do singleton; chamar de novo aqui garante que o primeiro render deste
        // componente já tenha dados (idempotente — LoadAsync sempre limpa e repopula as coleções).
        await ViewModel.LoadAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        ViewModel.SearchText = e.Value?.ToString() ?? "";
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnCollectionsChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelChanged;
        ViewModel.Researches.CollectionChanged -= OnCollectionsChanged;
        ViewModel.Tags.CollectionChanged -= OnCollectionsChanged;
    }
}
