@*
    Item de segmento da transcrição (T64): tempo, badge de locutor, texto editável e
    destaque `.active-seg` quando `IsActive` — fiel ao protótipo (`renderSegments` em
    transcriba-v2-icons-transcriptions.html).

    Texto via `<textarea>` estilizado como `.seg-text` (não `contenteditable`): o split no
    cursor usa `selectionStart`, mesma semântica de `sel.anchorOffset` do protótipo, com
    binding Blazor estável (`@bind` + `CommitText` no blur). `NotifyFocused(caretIndex)`
    é chamado em focus/click/keyup via `versoEditor.caretIndex` (editor.js).
*@
@implements IDisposable
@inject IJSRuntime JS

<div class="seg @(ViewModel.IsActive ? "active-seg" : "") @(ViewModel.IsEditing ? "editing" : "")" data-segment-id="@ViewModel.Id" @onclick="OnSegmentClick">
    <div class="seg-time">@ViewModel.TimeDisplay</div>
    <div class="seg-body">
        <div class="seg-speaker-slot">
            <button type="button" class="seg-speaker-chip @(string.IsNullOrEmpty(ViewModel.SpeakerName) ? "empty" : "")"
                    style="@(string.IsNullOrEmpty(ViewModel.SpeakerName) ? "" : $"color:{ViewModel.SpeakerColorHex}")"
                    title="@(string.IsNullOrEmpty(ViewModel.SpeakerName) ? "Atribuir locutor" : "Mudar locutor")"
                    @onclick="OnLocutorClick" @onclick:stopPropagation="true">
                @if (string.IsNullOrEmpty(ViewModel.SpeakerName))
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    <span>Locutor</span>
                }
                else
                {
                    <span class="seg-speaker-dot" style="background:@ViewModel.SpeakerColorHex"></span>
                    <span>@ViewModel.SpeakerName</span>
                }
            </button>
            @if (ViewModel.IsActive)
            {
                <SpeakerDropdown ViewModel="ViewModel.SpeakerDropdown" />
            }
        </div>
        <textarea @ref="_textArea" class="seg-text seg-text-area" rows="1"
                  @bind="ViewModel.Text" @bind:event="oninput"
                  @onfocus="OnFocusAsync"
                  @onclick="OnTextClickAsync"
                  @onkeyup="OnCaretUpdateAsync"
                  @onblur="OnBlur"
                  @onclick:stopPropagation="true"></textarea>
    </div>
    <div class="seg-actions">
        <button type="button" title="Dividir trecho" @onmousedown:preventDefault="true" @onclick="async () => await ViewModel.SplitCommand.ExecuteAsync(null)" @onclick:stopPropagation="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5" /><path d="M8 3H3v5" /><path d="M12 22v-8" /><path d="M21 3l-9 9" /><path d="M3 3l9 9" /></svg>
            Dividir
        </button>
        <button type="button" title="Mesclar com trecho anterior" @onmousedown:preventDefault="true" @onclick="async () => await ViewModel.MergeCommand.ExecuteAsync(null)" @onclick:stopPropagation="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6v6" /><path d="M16 6v6" /><path d="M2 12h20" /></svg>
            Mesclar
        </button>
    </div>
</div>

<style>
    .seg-text-area {
        width: 100%;
        border: none;
        background: transparent;
        resize: none;
        overflow: hidden;
        padding: 0;
        font: inherit;
        line-height: inherit;
        color: inherit;
        field-sizing: content;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public SegmentItemViewModel ViewModel { get; set; } = null!;

    private SegmentItemViewModel? _subscribed;
    private ElementReference _textArea;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_subscribed, ViewModel))
        {
            return;
        }

        Unsubscribe();
        _subscribed = ViewModel;
        ViewModel.PropertyChanged += OnViewModelChanged;
    }

    private void OnSegmentClick() => ViewModel.ClickCommand.Execute(null);

    private async Task OnFocusAsync()
    {
        ViewModel.IsEditing = true;
        await OnCaretUpdateAsync();
    }

    private async Task OnTextClickAsync(MouseEventArgs e)
    {
        await OnCaretUpdateAsync();
    }

    private async Task OnCaretUpdateAsync()
    {
        try
        {
            var idx = await JS.InvokeAsync<int>("versoEditor.caretIndex", _textArea);
            ViewModel.NotifyFocused(idx);
        }
        catch (JSDisconnectedException)
        {
            // WebView fechado — ignorar.
        }
    }

    private void OnBlur()
    {
        ViewModel.IsEditing = false;
        ViewModel.CommitText();
    }

    private void OnLocutorClick() => ViewModel.OpenLocutorCommand.Execute(null);

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void Unsubscribe()
    {
        if (_subscribed is null)
        {
            return;
        }

        _subscribed.PropertyChanged -= OnViewModelChanged;
    }

    public void Dispose() => Unsubscribe();
}
