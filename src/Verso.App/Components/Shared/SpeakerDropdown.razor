@*
    Dropdown de atribuição/renomeação de locutor (T64), reaproveitando
    `SpeakerDropdownViewModel`. Agora cada locutor existente pode ser renomeado
    inline (lápis → input → Enter salva / Esc cancela), além de selecionado.
*@
@using Verso.App.ViewModels
@implements IDisposable

<div class="speaker-dropdown @(ViewModel.IsOpen ? "open" : "")" @onclick:stopPropagation="true">
    <div class="speaker-dropdown-title">Selecionar locutor</div>
    @foreach (var speaker in ViewModel.Speakers)
    {
        var captured = speaker;
        <div class="speaker-option @(captured.IsActive ? "active" : "")">
            @if (captured.IsEditing)
            {
                <span class="sp-dot" style="background:@captured.ColorHex"></span>
                <input type="text" class="speaker-rename-input" value="@_renameText"
                       @oninput="OnRenameInput"
                       @onkeydown="(e) => OnRenameKeyDown(e, captured)"
                       @onclick:stopPropagation="true" @ref="_renameInput" />
            }
            else
            {
                <div class="speaker-option-main" @onclick="() => captured.SelectCommand.Execute(null)">
                    <span class="sp-dot" style="background:@captured.ColorHex"></span>
                    <span class="speaker-option-name">@captured.Name</span>
                </div>
                <button type="button" class="speaker-option-edit" title="Renomear locutor"
                        @onclick="() => StartRename(captured)" @onclick:stopPropagation="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                </button>
            }
        </div>
    }
    <div class="speaker-divider"></div>
    <div class="speaker-new-row">
        <input type="text" placeholder="Novo locutor…" value="@ViewModel.NewSpeakerName"
               @oninput="OnNewSpeakerInput" @onkeydown="OnNewSpeakerKeyDown" />
        <button type="button" disabled="@(!ViewModel.CanAssign)" @onclick="async () => await ViewModel.AddNewSpeakerCommand.ExecuteAsync(null)">Adicionar</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public SpeakerDropdownViewModel ViewModel { get; set; } = null!;

    private SpeakerDropdownViewModel? _subscribed;
    private string _renameText = "";
    private ElementReference _renameInput;
    private bool _shouldFocusRename;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_subscribed, ViewModel))
        {
            return;
        }

        Unsubscribe();
        _subscribed = ViewModel;
        ViewModel.PropertyChanged += OnViewModelChanged;
        ViewModel.Speakers.CollectionChanged += OnSpeakersChanged;
        SubscribeSpeakerOptions();
    }

    private void SubscribeSpeakerOptions()
    {
        foreach (var speaker in ViewModel.Speakers)
        {
            speaker.PropertyChanged += OnSpeakerOptionChanged;
        }
    }

    private void UnsubscribeSpeakerOptions()
    {
        foreach (var speaker in ViewModel.Speakers)
        {
            speaker.PropertyChanged -= OnSpeakerOptionChanged;
        }
    }

    private void OnSpeakerOptionChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnNewSpeakerInput(ChangeEventArgs e) =>
        ViewModel.NewSpeakerName = e.Value?.ToString() ?? "";

    private async Task OnNewSpeakerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && ViewModel.CanAssign)
        {
            await ViewModel.AddNewSpeakerCommand.ExecuteAsync(null);
        }
    }

    private void StartRename(SpeakerOptionViewModel option)
    {
        foreach (var s in ViewModel.Speakers)
        {
            s.IsEditing = false;
        }

        option.IsEditing = true;
        _renameText = option.Name;
        _shouldFocusRename = true;
    }

    private void OnRenameInput(ChangeEventArgs e) => _renameText = e.Value?.ToString() ?? "";

    private async Task OnRenameKeyDown(KeyboardEventArgs e, SpeakerOptionViewModel option)
    {
        if (e.Key == "Escape")
        {
            option.IsEditing = false;
            return;
        }

        if (e.Key == "Enter")
        {
            await ViewModel.RenameSpeakerCommand.ExecuteAsync((option, _renameText));
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (_shouldFocusRename)
        {
            _shouldFocusRename = false;
            _ = _renameInput.FocusAsync();
        }
    }

    private void OnViewModelChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void OnSpeakersChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        UnsubscribeSpeakerOptions();
        SubscribeSpeakerOptions();
        InvokeAsync(StateHasChanged);
    }

    private void Unsubscribe()
    {
        if (_subscribed is null)
        {
            return;
        }

        _subscribed.PropertyChanged -= OnViewModelChanged;
        _subscribed.Speakers.CollectionChanged -= OnSpeakersChanged;
        UnsubscribeSpeakerOptions();
    }

    public void Dispose() => Unsubscribe();
}