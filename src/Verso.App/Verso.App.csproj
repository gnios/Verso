<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <!--
      Shell cross-platform via Photino.Blazor: a mesma UI em Blazor (Razor components +
      ViewModels + wwwroot) agora roda em Windows, Linux e macOS sobre o webview nativo do SO
      (WebView2 no Windows, WebKitGTK no Linux, WebKit no macOS). Substitui o shell WPF +
      WebView2 (net10.0-windows) — ver migração em .specs/STATE.md.

      Photino.Blazor 4.0.13 publica apenas assets net8.0/net9.0; o NuGet faz fallback
      forward-compatible para net10.0 (verificado: restore + build limpos).
    -->
    <!-- WinExe: subsystem de GUI no Windows (sem janela de console no Release). No Linux
         e macOS é tratado igual a Exe — não há conceito de janela de console ao abrir. -->
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <RootNamespace>Verso.App</RootNamespace>
    <AssemblyName>Verso</AssemblyName>
    <ApplicationIcon>Assets\verso.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Verso.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Photino.Blazor" Version="4.0.13" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.9">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.9" />
    <PackageReference Include="System.Management" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Verso.Core\Verso.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Gera o manifesto dos recursos embutidos (wwwroot) p/ ManifestEmbeddedFileProvider. -->
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
  </PropertyGroup>

  <ItemGroup>
    <!-- wwwroot embarcado DENTRO do exe: o ManifestEmbeddedFileProvider (passado em
         Program.cs) serve o HostPage/HTML/CSS/JS dos recursos embutidos, sem pasta solta
         no disco. Mantemos o wwwroot como Content (static web assets do framework —
         blazor.webview.js) e o embutimos também como recurso p/ o file provider. -->
    <EmbeddedResource Include="wwwroot\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <!-- O ícone precisa ficar no disco: SetIconFile lê por caminho (não recurso). -->
    <Content Include="Assets\verso.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>